DISCORD_BOT_TOKEN=
GUILD_ID=
DATABASE_URL=sqlite:///valorlink.db

# --- Web UI (optional; only needed to run the Regimental Headquarters site) ---
# Secret used to sign session cookies. Set a long random value in production.
WEB_SESSION_SECRET=
# Set to 1 only when the site is served over HTTPS.
WEB_HTTPS_ONLY=
# Local-only "act as" sign-in for development/testing. Leave unset in production.
WEB_DEV_LOGIN=

# --- Discord OAuth2 for officer sign-in (optional) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Full callback URL, e.g. https://hq.example.com/auth/discord/callback
DISCORD_OAUTH_REDIRECT=
