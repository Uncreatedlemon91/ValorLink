# ValorLink production environment. Copy to /opt/valorlink/.env, fill in,
# then `chmod 600 /opt/valorlink/.env`. Both systemd units read this file.

# --- Core / secrets ---
DISCORD_BOT_TOKEN=
GUILD_ID=

# Absolute path so the bot and the web unit open the SAME database file.
# (Four slashes: sqlite:/// + /opt/valorlink/valorlink.db)
DATABASE_URL=sqlite:////opt/valorlink/valorlink.db

# --- Web UI ---
# Signs session cookies. Keep it stable (regenerating logs everyone out).
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WEB_SESSION_SECRET=
# Served over HTTPS behind Caddy, so mark session cookies secure.
WEB_HTTPS_ONLY=1
# Leave WEB_DEV_LOGIN unset in production (it enables an unauthenticated
# "act as" login meant only for local development).

# --- Discord OAuth2 (officer sign-in) ---
# From your Discord application's OAuth2 page. The redirect must match
# exactly what you register there.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT=https://hq.example.com/auth/discord/callback

# --- Multi-unit / multi-tenant (optional; leave unset for a single unit) ---
# When set, subdomains of this domain resolve to units (e.g. 5thva.valorlink.co);
# the bare domain serves the default unit. Unset = single-unit mode.
# PLATFORM_BASE_DOMAIN=valorlink.co
# Share the login cookie across all unit subdomains (note the leading dot).
# Required for signing into a unit on its own subdomain.
# SESSION_COOKIE_DOMAIN=.valorlink.co
# Where the registry and per-unit databases live (defaults shown).
# REGISTRY_DATABASE_URL=sqlite:////opt/valorlink/registry.db
# UNIT_DB_DIR=/opt/valorlink/units
# Slug the bare domain / current deployment resolves to.
# PLATFORM_DEFAULT_SLUG=hq
